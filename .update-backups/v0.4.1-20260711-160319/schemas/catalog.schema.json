{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://love-right.coseclab.dev/schemas/catalog.schema.json",
  "title": "Love Right Story Catalog",
  "type": "object",
  "required": ["schemaVersion", "stories"],
  "properties": {
    "schemaVersion": {"const": 1},
    "stories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "slug", "status", "title", "storyUrl", "resultsUrl"],
        "properties": {
          "id": {"type": "string"}, "slug": {"type": "string"},
          "status": {"enum": ["draft", "published", "archived"]},
          "title": {"type": "string"}, "series": {"type": "string"}, "description": {"type": "string"},
          "estimatedMinutes": {"type": "integer"}, "coverTheme": {"type": "string"},
          "storyUrl": {"type": "string"}, "resultsUrl": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
