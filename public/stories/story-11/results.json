  "sections": {
    "ending": {
      "byOutcome": {
        "together": "你没有把允许程野进门当成欠下人情。搬家后的新旧地址之间，你们仍然会约好时间：他带着露营灯来，你决定门要不要开。水槽不再漏水，楼道也亮着；靠近是一件可以重复确认的普通事。",
        "slow": "你们没有急着把关系写成答案。程野仍住在楼下，你也仍有自己的搬家清单；偶尔在楼道相遇、一起倒垃圾，偶尔约好吃饭。慢一点不是撤退，而是让每一次进入私人空间都经过同意。",
        "separate-close": "你搬走了，却没有把离开老楼写成对程野的否定。你们隔着新的地址联系，聊起露营灯和那次水槽漏水。关系不占据生活，也不被生活抹掉。",
        "pause": "你选择把关系停在这里。程野没有用修水槽、借灯或搬箱子要求回报；你也没有把暂停解释成伤害谁。老楼的门仍由你开关，新的日子从这一点开始。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "appeal",
            "equals": "steady"
          },
          "text": "他没有追问你为什么来，只把一直替你留着的另一张票递给你。海风吹过纸角，也把那句迟到的“我在等你”轻轻送到你面前。"
        },
        {
          "when": {
            "flag": "appeal",
            "equals": "witty"
          },
          "text": "他看见你时先笑了：“这次没有走错馆吧？”你也笑了。那些一路上的紧张，忽然被一句只有你们懂的话变得很轻。"
        },
        {
          "when": {
            "flag": "appeal",
            "equals": "gentle"
          },
          "text": "他先问你冷不冷，又停了一下，认真问：“我可以抱你吗？”你点头以后，海风像是忽然绕开了你们。"
        },
        {
          "when": {
            "flag": "appeal",
            "equals": "direct"
          },
          "text": "他没有再让你猜，只看着你说：“我喜欢你，也想认真走下去。”这一次，心动终于有了清楚的声音。"
        },
        {
          "default": true,
          "text": "你正在学习让心动和判断同时存在。真正适合你的浪漫，不会要求你取消边界，只会让你更愿意向前一步。"
        }
      ]
    },
    "psychology": {
      "byArchetype": {
        "clear-slow": "你会观察对方是否尊重水槽、露营灯和搬家这些小事里的边界；真正让你安心的，是程野先等你的允许。",
        "steady-confirm": "你会观察对方是否尊重水槽、露营灯和搬家这些小事里的边界；真正让你安心的，是程野先等你的允许。",
        "romantic-resonance": "你会观察对方是否尊重水槽、露营灯和搬家这些小事里的边界；真正让你安心的，是程野先等你的允许。",
        "direct-pursuit": "你会观察对方是否尊重水槽、露营灯和搬家这些小事里的边界；真正让你安心的，是程野先等你的允许。",
        "free-close": "你会观察对方是否尊重水槽、露营灯和搬家这些小事里的边界；真正让你安心的，是程野先等你的允许。",
        "chosen-sensitive": "你会观察对方是否尊重水槽、露营灯和搬家这些小事里的边界；真正让你安心的，是程野先等你的允许。",
        "repair-nurturer": "你会观察对方是否尊重水槽、露营灯和搬家这些小事里的边界；真正让你安心的，是程野先等你的允许。",
        "push-pull": "你会观察对方是否尊重水槽、露营灯和搬家这些小事里的边界；真正让你安心的，是程野先等你的允许。"
      },
      "appendRules": [
        {
          "when": {
            "path": "spatial.trend.approach",
            "op": ">=",
            "value": 0.18
          },
          "text": "你在故事后半段明显比开始时更愿意靠近。你并非被第一眼征服，而是会被持续一致的细节慢慢说服。"
        },
        {
          "when": {
            "path": "spatial.trend.approach",
            "op": "<=",
            "value": -0.18
          },
          "text": "越接近现实选择，你反而越会收回冲动。你需要确认对方能承担关系，而不只是擅长让人心动。"
        },
        {
          "when": {
            "trait": "autonomy",
            "gte": 62
          },
          "text": "你需要亲密，也需要完整的自我。对方越尊重你的节奏，你越可能主动把他放进生活。"
        },
        {
          "default": true,
          "text": "你在靠近与保留之间相对平衡，不会立刻交出全部，也不需要靠故意冷淡证明自己。"
        }
      ]
    },
    "history": {
      "groups": [
        [
          {
            "default": true,
            "text": "你可能很早就学会把帮助和人情债分开，所以更珍惜不要求回报的靠近。"
          }
        ],
        [
          {
            "default": true,
            "text": "你对私人空间的谨慎，不是冷淡；它让你能在愿意时更清楚地说是。"
          }
        ]
      ]
    },
    "future": [
      {
        "title": "楼道",
        "rules": [
          {
            "default": true,
            "text": "下一次相遇发生在亮着灯的楼道，你先决定要不要停下来。"
          }
        ]
      },
      {
        "title": "搬家",
        "rules": [
          {
            "default": true,
            "text": "新的纸箱被拆开，关系不替你选择住处，只陪你把日子安顿好。"
          }
        ]
      },
      {
        "title": "露营灯",
        "rules": [
          {
            "default": true,
            "text": "一盏露营灯提醒你：被照顾不等于失去自己。"
          }
        ]
      }
    ],
    "match": {
      "base": "适合你的人会先问能不能进门、能不能帮忙，也接受你选择等物业或独处。",
      "appendRules": []
    },
    "warning": {
      "rules": [
        {
          "default": true,
          "text": "别把一次顺手的帮助当成必须交换亲密的理由；愿意尊重你的人不会这样要求。"
        }
      ]
    }
  }
