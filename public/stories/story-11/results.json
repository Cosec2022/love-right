  "sections": {
    "ending": {
      "byOutcome": {
        "together": "你和程野正式开始交往。第一次真正以男朋友身份来找你时，他没有带菜，也没有用店里的事情作借口。吸引仍然存在，规则也仍然存在；他学会先问，你也允许自己在看清缺点以后继续喜欢。",
        "slow": "你们约定先认真约会三次，而且都不在他的店里。没有食物、工作和楼道停电替你们制造气氛，接下来只看两个普通人能不能继续想见彼此。",
        "separate-close": "你承认程野有吸引力，也承认这份吸引不适合发展成恋爱。你们保留邻居和熟客的位置，不再让每一次敲门、留座或试菜带着额外含义。",
        "pause": "你结束了私人关系。程野没有用新菜单、新菜或更漂亮的道歉要求你改变答案。楼下的香气仍会飘上来，但它不再是你们之间未完成的暗号。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "kiss_mode",
            "equals": "kiss"
          },
          "text": "你们确实接过吻；它证明吸引真实存在，却没有替任何人获得免错权。"
        },
        {
          "when": {
            "flag": "breach_response",
            "equals": "leave"
          },
          "text": "你曾经离开他的开业夜，让程野明白，喜欢不能把别人的私话自动变成自己的作品。"
        },
        {
          "when": {
            "flag": "date_answer",
            "equals": "no"
          },
          "text": "你已经拒绝过一次正式约会，最后的答案因此不是被气氛推着发生。"
        },
        {
          "default": true,
          "text": "最后的关系不会抹掉菜单上的越界，也不会否认你们之间确实发生过的欲望。"
        }
      ]
    },
    "psychology": {
      "byArchetype": {
        "clear-slow": "你不会因为一个男人好看、会做饭、又明确喜欢你，就立刻把吸引等同于适合。你更在意他做错以后有没有真正承担代价。",
        "steady-confirm": "你喜欢清楚的选择：为什么敲门、是不是约会、想不想接吻、这段关系叫什么。明确并不会削弱浪漫，反而让你更能放心心动。",
        "romantic-resonance": "你会记住雨水落在他肩头的颜色、料理台上的蒸汽、黑暗里停在半空的手。你很容易被只属于两个人的细节打动。",
        "direct-pursuit": "你不喜欢把欲望一直藏在玩笑和借口后面。喜欢可以说，生气也可以说；你要的是两个成年人都承担自己表达出来的东西。",
        "free-close": "你允许一个人靠近你的身体和生活，却不会因此把自己的门、时间和决定权交出去。真正适合的人不会把亲密理解成默认进入。",
        "chosen-sensitive": "你最深的满足来自被具体选择：他不是缺一个试菜的人，而是想见你；他不是对所有邻居都留位置，而是写了你的名字。",
        "repair-nurturer": "你愿意听不够漂亮的道歉，也能看见一个人的缺点怎样与魅力长在一起。但修复必须由他自己完成，而不是你替他解释。",
        "push-pull": "程野的身体存在感和直接欲望让你靠近，他擅自使用私话又让你退后。你的拉扯是在判断：这份强烈吸引会不会同时尊重你。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "taste_truth",
            "equals": "specific"
          },
          "text": "你从一开始就不靠夸奖换取好感，真实意见本身也是你建立亲密的方式。"
        },
        {
          "when": {
            "flag": "touch_mode",
            "equals": "hand"
          },
          "text": "你愿意在对方先询问以后接受身体靠近，说明边界并不会让你失去欲望。"
        },
        {
          "when": {
            "flag": "breach_focus",
            "equals": "material"
          },
          "text": "你对“喜欢就可以拿走”格外警觉。被欣赏和被占用，对你来说从来不是同一件事。"
        },
        {
          "default": true,
          "text": "你在故事里反复区分心动、偏爱、作品和许可。它们可以同时存在，却不能互相代替。"
        }
      ]
    },
    "history": {
      "groups": [
        [
          {
            "when": {
              "flag": "first_tone",
              "equals": "playful"
            },
            "text": "你通常愿意用轻松和幽默打开第一步，但这不表示后续所有靠近都会被默认接受。"
          },
          {
            "when": {
              "flag": "first_tone",
              "equals": "verify"
            },
            "text": "你习惯先确认现实信息，再决定要不要让陌生人靠近。谨慎不妨碍你后来产生强烈吸引。"
          },
          {
            "default": true,
            "text": "你对第一印象有感觉，也会给自己时间判断这个人除了外表之外，是否真的值得继续。"
          }
        ],
        [
          {
            "when": {
              "flag": "repair_response",
              "equals": "both"
            },
            "text": "你能同时承认愤怒和欲望，不需要为了证明边界而假装自己从未心动。"
          },
          {
            "when": {
              "flag": "repair_response",
              "equals": "end"
            },
            "text": "当一个错误触及你的核心界线时，你不会因为此前有过吸引就强迫自己继续。"
          },
          {
            "default": true,
            "text": "你可能经历过别人把欣赏、照顾或创作欲当成越界的理由，因此更看重对方有没有能力先问。"
          }
        ]
      ]
    },
    "future": [
      {
        "title": "下一次被具体看见",
        "rules": [
          {
            "default": true,
            "text": "下一段让你真正投入的关系，不只是有人对你好，而是他能说出为什么偏偏注意你，又愿意承担你的真实回答。"
          }
        ]
      },
      {
        "title": "欲望和许可",
        "rules": [
          {
            "default": true,
            "text": "你不需要在心动和边界之间二选一。更成熟的亲密，是欲望足够明确，询问也同样明确。"
          }
        ]
      },
      {
        "title": "错误以后",
        "rules": [
          {
            "default": true,
            "text": "你会继续观察一个人犯错后的第一反应：先保护自己，还是先看见你；真正的修复往往从这一区别开始。"
          }
        ]
      }
    ],
    "match": {
      "base": "适合你的人首先应该让你真的想靠近。他有外表、有欲望、有自己的世界，也有能力在做错以后承担代价，而不是只会提供正确答案。",
      "appendRules": [
        {
          "when": {
            "trait": "validation",
            "gte": 58
          },
          "text": "他需要让偏爱落在具体行动里，不让你长期猜自己是不是特别。"
        },
        {
          "when": {
            "trait": "autonomy",
            "gte": 58
          },
          "text": "他必须有自己的事业和生活，也尊重你不成为他的素材、助手或附属。"
        },
        {
          "when": {
            "trait": "repair",
            "gte": 58
          },
          "text": "他可以有锋芒和缺点，但不能把理解、解释和修复都留给你完成。"
        }
      ]
    },
    "warning": {
      "rules": [
        {
          "when": {
            "all": [
              {
                "trait": "idealization",
                "gte": 58
              },
              {
                "trait": "discernment",
                "lte": 48
              }
            ]
          },
          "text": "强烈的外表和氛围吸引可能让你替对方跳过一些需要核实的部分。心动可以先发生，判断仍然要继续。"
        },
        {
          "when": {
            "trait": "care",
            "gte": 60
          },
          "text": "不要因为看见一个人疲惫、焦虑或害怕被拒绝，就替他减轻未经允许做事的责任。"
        },
        {
          "default": true,
          "text": "一个人好看、会做饭、又明确喜欢你，当然值得心动；但真正适合继续的人，还必须能接受你说不，并在做错以后不靠魅力逃掉。"
        }
      ]
    }
  }
}