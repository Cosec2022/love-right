  "sections": {
    "ending": {
      "byOutcome": {
        "together": "你和程野正式开始交往。第一次以男朋友身份来找你时，他没有带菜，也没有让你替店里做任何事。你们去了河边，回程时他牵住你的手，走到楼梯口又停下来问你要不要一起上楼。喜欢仍然很具体：他会想见你、想吻你，也学会先问你愿不愿意。",
        "slow": "你们约定先认真约会三次，而且都不在他的店里。没有锅、试菜和开业夜替你们制造气氛，接下来只看两个普通人能不能继续想见彼此。",
        "separate-close": "你承认程野有吸引力，也承认这份吸引不适合继续发展成恋爱。你们保留楼上楼下的距离，不再让每次敲门都带着额外含义。",
        "pause": "你结束了私人关系。程野没有再用新菜、道歉或忙乱中的需要要求你改变答案。楼下仍会有香气飘上来，但它不再是你们之间的暗号。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "kiss_mode",
            "equals": "kiss"
          },
          "text": "你们确实接过吻；它证明吸引真实存在，却没有替任何人获得免错权。"
        },
        {
          "when": {
            "flag": "crisis_response",
            "equals": "limited_help"
          },
          "text": "你曾经在开业夜帮过他十分钟，也明确让这十分钟按时结束。"
        },
        {
          "when": {
            "flag": "date_answer",
            "equals": "later"
          },
          "text": "你曾经要求他等店开稳一个月再来，这个答案不是被道歉或气氛催出来的。"
        },
        {
          "default": true,
          "text": "最后的关系不会抹掉开业夜的越界，也不会否认你们之间真实发生过的欲望。"
        }
      ]
    },
    "psychology": {
      "byArchetype": {
        "clear-slow": "你不会因为一个男人好看、会做饭、又明确喜欢你，就立刻把吸引等同于适合。你更在意他忙乱时是否仍然记得先问。",
        "steady-confirm": "你喜欢清楚的关系语言：试菜不是约会，约会不是默认恋爱，喜欢也不能替代许可。明确反而让你更能放心心动。",
        "romantic-resonance": "你会被具体的场景打动：雨湿的灰色T恤、料理台的火光、楼道里偏低的声音，以及他第一次承认想见你的那一刻。",
        "direct-pursuit": "你不喜欢把欲望一直藏在锅、汤和试菜后面。喜欢可以直说，不满也可以直说；你要两个成年人都承担自己的表达。",
        "free-close": "你允许一个人靠近你的身体和生活，却不会因此自动进入他的工作、安排或未来。真正适合的人不会把亲密理解成默认同意。",
        "chosen-sensitive": "你最深的满足来自被具体选择：他不是缺一个帮手，而是偏偏想见你；他不是因为你有用，而是第一眼就被你吸引。",
        "repair-nurturer": "你愿意听一个不够漂亮的道歉，也能看见魅力和缺点同时存在。但修复必须由他自己完成，而不是由你替他解释。",
        "push-pull": "程野的身体存在感和直接欲望让你靠近，他在开业夜替你安排位置又让你退后。你的拉扯是在判断：这份强烈吸引会不会尊重你。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "taste_truth",
            "equals": "specific"
          },
          "text": "你从一开始就不靠夸奖换取好感，真实意见本身也是你建立亲密的方式。"
        },
        {
          "when": {
            "flag": "kiss_mode",
            "equals": "kiss"
          },
          "text": "你愿意在对方明确询问后接受身体靠近，说明边界并不会削弱欲望。"
        },
        {
          "when": {
            "flag": "breach_focus",
            "equals": "role"
          },
          "text": "你对“被喜欢”与“被安排”之间的差别格外敏感。"
        },
        {
          "default": true,
          "text": "你在故事里反复区分心动、偏爱、帮助和默认义务。它们可以同时存在，却不能互相代替。"
        }
      ]
    },
    "history": {
      "groups": [
        [
          {
            "when": {
              "flag": "first_tone",
              "equals": "playful"
            },
            "text": "你愿意用轻松和幽默打开第一步，但不会因此默认后续所有靠近。"
          },
          {
            "when": {
              "flag": "first_tone",
              "equals": "verify"
            },
            "text": "你先确认现实信息，再决定是否让陌生人靠近。谨慎没有妨碍你后来产生吸引。"
          },
          {
            "default": true,
            "text": "你对第一印象有感觉，也会继续观察这个人除了外表之外是否值得。"
          }
        ],
        [
          {
            "when": {
              "flag": "crisis_response",
              "equals": "limited_help"
            },
            "text": "你可以在紧急时帮忙，也会把帮助的范围说清楚。"
          },
          {
            "when": {
              "flag": "crisis_response",
              "equals": "guest"
            },
            "text": "你没有因为喜欢他，就把自己从客人自动变成免费帮手。"
          },
          {
            "default": true,
            "text": "你愿意靠近一个有自己事业的人，但不会把支持理解成随叫随到。"
          }
        ]
      ]
    },
    "future": [
      {
        "title": "下一次被具体选择",
        "rules": [
          {
            "default": true,
            "text": "下一段真正适合你的关系，不只是有人需要你，而是他能说清为什么偏偏想见你，并愿意承担你的真实回答。"
          }
        ]
      },
      {
        "title": "吸引和安排",
        "rules": [
          {
            "default": true,
            "text": "你可以被一个人的外表、能力和欲望打动，同时继续判断他会不会把亲密误解成默认配合。"
          }
        ]
      },
      {
        "title": "错误以后",
        "rules": [
          {
            "default": true,
            "text": "你会继续观察一个人犯错后的第一反应：先怪你没理解，还是愿意承认自己替你做了决定。"
          }
        ]
      }
    ],
    "match": {
      "base": "适合你的人首先应该让你真的想靠近。他有外表、有欲望、有自己的世界，也有能力在做错以后承担代价，而不是只会给出正确答案。",
      "appendRules": [
        {
          "when": {
            "trait": "validation",
            "gte": 58
          },
          "text": "他需要让偏爱落在具体行动里，不让你长期猜自己是不是特别。"
        },
        {
          "when": {
            "trait": "autonomy",
            "gte": 58
          },
          "text": "他必须有自己的事业，也尊重你不成为他的助手、员工或附属。"
        },
        {
          "when": {
            "trait": "repair",
            "gte": 58
          },
          "text": "他可以有锋芒和缺点，但不能把理解和修复都留给你完成。"
        }
      ]
    },
    "warning": {
      "rules": [
        {
          "when": {
            "all": [
              {
                "trait": "idealization",
                "gte": 58
              },
              {
                "trait": "discernment",
                "lte": 48
              }
            ]
          },
          "text": "强烈的外表和氛围吸引可能让你替对方跳过一些需要核实的部分。心动可以先发生，判断仍然要继续。"
        },
        {
          "when": {
            "trait": "care",
            "gte": 60
          },
          "text": "不要因为看见一个人忙、累或害怕失败，就把自己自动放进救场的位置。"
        },
        {
          "default": true,
          "text": "一个人好看、会做饭、又明确喜欢你，当然值得心动；但真正适合继续的人，还必须能接受你说不，也不能把支持当成默认义务。"
        }
      ]
    }
  }
}