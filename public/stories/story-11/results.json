  "sections": {
    "ending": {
      "byOutcome": {
        "together": "你们正式开始交往。无论你最后住在旧楼、新楼还是另一个地址，程野都不再把“顺手帮忙”当成进入生活的通行证。第一次以男朋友身份来找你时，他仍然站在门外敲门。你开门，不是因为欠下人情，而是因为这次你确实想让他进来。",
        "slow": "你们约定先认真约会三次。没有停水、漏水和搬家替你们制造见面，也没有谁把“三次以后”写成默认答案。你会看见他在普通日子里怎样表达、怎样处理失望，再决定这段关系要不要继续。",
        "separate-close": "你把关系留在朋友和邻居的位置。程野仍会在楼道见到你，但不会再用借灯、送橘子或维修制造额外含义。你们可以关心彼此，也接受有些亲近不必发展成爱情。",
        "pause": "你结束了这段私人关系。程野没有再找一个需要修理的东西回来，也没有把沉默变成等待你心软的策略。门关上以后，旧楼仍然是你的生活，不是你们未完成的爱情纪念馆。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "move_plan",
            "equals": "move"
          },
          "text": "你已经搬到新的地址。关系是否继续，不再取决于上下楼的便利。"
        },
        {
          "when": {
            "flag": "move_plan",
            "equals": "stay"
          },
          "text": "你选择留在老楼，是因为它仍然适合你的生活，不是谁赢得了你留下。"
        },
        {
          "when": {
            "flag": "move_plan",
            "equals": "trial"
          },
          "text": "你让现实生活先经过试住，而不是让心动替你决定住所。"
        },
        {
          "when": {
            "flag": "move_plan",
            "equals": "elsewhere"
          },
          "text": "你去了第三个地方，也保留了所有关系都必须重新约定的权利。"
        },
        {
          "default": true,
          "text": "这段关系最后怎样命名，不能抹掉此前发生过的越界，也不能否认真实存在过的靠近。"
        }
      ]
    },
    "psychology": {
      "byArchetype": {
        "clear-slow": "你不会因为一个人会修东西、会照顾邻居，就立刻把可靠等同于适合。你更看重他在被拒绝、被质疑和做错以后，能否真正调整行为。",
        "steady-confirm": "你需要关系从“顺便帮忙”走向明确邀请。门能不能开、下一次什么时候见、彼此是什么关系，清楚的安排会比暧昧的体贴更让你安心。",
        "romantic-resonance": "你很容易记住生活里的小暗号：锅底的字、门把上的橘子、楼顶被风吹起的床单。它们会让你心动，但你仍需要这些细节最后落到真实尊重。",
        "direct-pursuit": "你愿意直接指出越界，也愿意在喜欢时给出清楚回应。你很难忍受两个人明明在靠近，却一直拿维修、停电和偶遇代替真正的邀请。",
        "free-close": "你允许别人进入生活，却不会因此交出住所、时间和决定权。越尊重你完整生活的人，越可能得到你主动打开的门。",
        "chosen-sensitive": "你最在意的不是程野为你做了多少，而是他有没有把你当作能够回答的人。被询问、被放进计划，比被默默安排更能让你感到被选择。",
        "repair-nurturer": "你能看见一个人越界背后的焦虑，也愿意听一份不够漂亮的道歉。但你真正接受的是具体修正，而不是替他把所有好意解释成无罪。",
        "push-pull": "他的可靠会让你靠近，他擅自替你决定又会让你立刻退后。你的摇摆并非故意，而是在判断这段亲密究竟会扩大生活，还是侵占生活。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "boundary_style",
            "equals": "direct"
          },
          "text": "你习惯在越界发生时立刻指出，这能减少长期累积的怨气。"
        },
        {
          "when": {
            "flag": "conflict_mode",
            "equals": "space"
          },
          "text": "你在冲突后需要真实的安静，而不是更多解释追着你发生。"
        },
        {
          "when": {
            "flag": "repair_gate",
            "equals": "specific"
          },
          "text": "你不会被一句抽象的“对不起”说服，更需要对方准确知道自己做错了什么。"
        },
        {
          "default": true,
          "text": "你在故事里不断区分帮助、好感和进入私人生活的权利；它们可以相关，却从来不是同一件事。"
        }
      ]
    },
    "history": {
      "groups": [
        [
          {
            "when": {
              "flag": "breach_focus",
              "equals": "consent"
            },
            "text": "你对“为了你好，所以没时间问你”格外敏感。你可能经历过别人用效率或关心替你做决定，因此更需要自己的回答被真正等待。"
          },
          {
            "when": {
              "flag": "breach_focus",
              "equals": "objects"
            },
            "text": "私人空间对你而言不仅是一扇门，也包括物品、秩序和不愿被别人看见的部分。别人怎样对待这些细节，会直接影响你的信任。"
          },
          {
            "default": true,
            "text": "你并不排斥接受帮助，只是不愿意让帮助自动变成人情债、亲密资格或替你决定的理由。"
          }
        ],
        [
          {
            "when": {
              "flag": "helper_view",
              "equals": "support"
            },
            "text": "你愿意支持别人改变，但会提醒自己：成长必须由对方亲自完成，不能又变成你替他解决。"
          },
          {
            "when": {
              "flag": "helper_view",
              "equals": "mirror"
            },
            "text": "你很快能看见一个人的优点怎样同时成为缺点。程野的“有用”既让人安心，也可能让他越过别人。"
          },
          {
            "default": true,
            "text": "你可能曾遇到过看起来很可靠的人，却在相处后发现，真正的可靠还包括询问、承认错误和接受拒绝。"
          }
        ]
      ]
    },
    "future": [
      {
        "title": "下一次敲门",
        "rules": [
          {
            "default": true,
            "text": "下一段重要关系更可能从普通日常开始。真正的转折不是对方替你解决麻烦，而是他第一次不靠任何借口，直接问你愿不愿意见面。"
          }
        ]
      },
      {
        "title": "住在哪里",
        "rules": [
          {
            "when": {
              "flag": "move_plan",
              "equals": "move"
            },
            "text": "新的地址会让你更清楚：真正能继续的关系，不依赖随时可以上下楼。"
          },
          {
            "default": true,
            "text": "住所、工作和生活习惯不会自动证明爱情。适合的关系会参与现实，但不会吞掉现实。"
          }
        ]
      },
      {
        "title": "真正的修复",
        "rules": [
          {
            "default": true,
            "text": "下一次冲突里，你会更注意对方能否准确说出自己做错了什么，并让新的行为持续出现，而不是只在当晚说得动听。"
          }
        ]
      }
    ],
    "match": {
      "base": "适合你的人不必什么都会修，但必须知道：进入你的时间、空间和生活，需要询问，而不是凭自己觉得有必要。",
      "appendRules": [
        {
          "when": {
            "trait": "expression",
            "lte": 44
          },
          "text": "他最好愿意主动问，而不是等你把不舒服积累成彻底关门。"
        },
        {
          "when": {
            "trait": "autonomy",
            "gte": 58
          },
          "text": "他需要有自己的目标和生活，不把亲密理解成随时介入。"
        },
        {
          "when": {
            "trait": "repair",
            "gte": 58
          },
          "text": "他也要有修复能力，不能每次都由你解释他的动机、完成他的成长。"
        }
      ]
    },
    "warning": {
      "rules": [
        {
          "when": {
            "all": [
              {
                "trait": "care",
                "gte": 58
              },
              {
                "trait": "discernment",
                "lte": 48
              }
            ]
          },
          "text": "你容易因为一个人长期有用、会照顾别人，就替他忽略越界。请继续分辨：他是在帮助，还是在用帮助获得默认的进入权。"
        },
        {
          "when": {
            "trait": "autonomy",
            "gte": 63
          },
          "text": "保护私人空间很重要，但也别把所有协调和共同承担都视为侵入。关键不是永远不让人靠近，而是靠近是否经过双方同意。"
        },
        {
          "default": true,
          "text": "不要把“他为我做了很多”直接换算成“他适合进入我的生活”。真正值得留下的人，也必须能听见拒绝、承认错误，并在没有麻烦可解决时仍然愿意认真约你。"
        }
      ]
    }
  }
}
