  "sections": {
    "ending": {
      "byOutcome": {
        "partner": "你选择和许知行正式交往。你喜欢他的外表、能力和认真，也看见他曾把另一个人的时间塞进自己的计划。关系真正开始，不是因为他从此永远准时，而是他终于学会在变化发生前把你当作需要一起决定的人。",
        "steady": "你选择继续认真约会，但暂时不定义关系。接下来的星期天不再是考试，也不需要靠身份保证安全。你们只看一件事：在计划改变、工作挤进来和心动退潮以后，是否仍然愿意见彼此。",
        "friends": "你把许知行留在朋友的位置。吸引、欣赏和一次真实的吻都可以存在，却不必被推成恋爱。你没有因为他变得更好，就把自己的答案改成奖励。",
        "end": "你结束了这段关系。许知行没有再用准时、道歉或一个更完美的星期天请求你重来。你把时间还给自己，也确认一个人值得欣赏，并不等于必须留下。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "kiss_mode",
            "equals": "kiss"
          },
          "text": "你们确实接过吻；它确认吸引存在，却没有替后面的关系自动作答。"
        },
        {
          "when": {
            "flag": "emergency_route",
            "equals": "wait"
          },
          "text": "你曾经给过明确的二十分钟，也在时间被超过时重新决定自己还等不等。"
        },
        {
          "when": {
            "flag": "second_sunday",
            "equals": "month"
          },
          "text": "你让他等了一个月，而他没有用持续追求突破这个条件。"
        },
        {
          "default": true,
          "text": "最后的结果没有抹掉第一次约会里的隐瞒，也没有否认后来真实发生的吸引。"
        }
      ]
    },
    "psychology": {
      "byArchetype": {
        "clear-slow": "你不会因为一个男人好看、守时、又在工作时很有魅力，就立刻把这些优点等同于适合。你更在意他怎样处理计划之外的你。",
        "steady-confirm": "你并不要求关系永远按时运行。真正让你安心的是：变化发生前有说明，发生后有修复，下一步由两个人共同决定。",
        "romantic-resonance": "你会被具体的场景打动：放映机的白光、雨棚下低下来的声音、空影院里最后一场电影，以及一句没有绕开的“第一眼，因为你好看”。",
        "direct-pursuit": "你不喜欢让含糊替人省事。想见就说，不能赴约也说；你愿意靠近一个人，也会直接指出他把你塞进了自己的时间表。",
        "free-close": "你允许关系进入一部分日常，却不会把星期天、朋友和独处全部让出来。适合你的亲密必须给两个人都留有完整生活。",
        "chosen-sensitive": "你需要确认自己不是被安排进空档、不是影院关门后的陪伴替代品。真正让你动心的是他在忙碌之外仍然具体地选择你。",
        "repair-nurturer": "你愿意给错误一次修复机会，但修复必须由他承担：承认隐瞒、接受你的等待期限，并在之后的普通日子里持续做到。",
        "push-pull": "许知行的外表、能力和直接让你靠近；他那句“十分钟”和未说出口的最后放映又让你退后。你在判断强烈吸引是否能长成可靠关系。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "first_tone",
            "equals": "direct"
          },
          "text": "你从第一幕就愿意承认外表吸引，不需要假装心动不存在。"
        },
        {
          "when": {
            "flag": "kiss_mode",
            "equals": "no"
          },
          "text": "你没有因为气氛已经足够浪漫，就提前交出身体上的同意。"
        },
        {
          "when": {
            "flag": "schedule_plan",
            "equals": "not_fit"
          },
          "text": "你会把现实节奏纳入判断，不让喜欢替你承诺长期不舒服的安排。"
        },
        {
          "default": true,
          "text": "你在这段故事里反复区分准时、可靠、吸引和适合；它们有关，却从来不是同一件事。"
        }
      ]
    },
    "history": {
      "groups": [
        [
          {
            "when": {
              "flag": "emergency_route",
              "equals": "follow"
            },
            "text": "你曾走进他的工作现场，看见能力，也没有因此自动成为帮手。"
          },
          {
            "when": {
              "flag": "emergency_route",
              "equals": "wait"
            },
            "text": "你愿意等待一段明确的时间，但不把无限延期包装成体谅。"
          },
          {
            "when": {
              "flag": "emergency_route",
              "equals": "leave_talk"
            },
            "text": "你可以理解紧急情况，也能让一次约会在该结束时结束。"
          },
          {
            "default": true,
            "text": "当他突然离场时，你首先保护了自己对时间和解释的需要。"
          }
        ],
        [
          {
            "when": {
              "flag": "second_sunday",
              "equals": "month"
            },
            "text": "你让第二次机会经过一个月，而不是让当下的歉意替你决定。"
          },
          {
            "when": {
              "flag": "second_sunday",
              "equals": "write"
            },
            "text": "你先要一个能独立成立的答案，再决定是否见面。"
          },
          {
            "default": true,
            "text": "你给出的第二次机会有清楚条件，不是被气氛推着重新开始。"
          }
        ]
      ]
    },
    "future": [
      {
        "title": "时间改变时",
        "rules": [
          {
            "default": true,
            "text": "适合你的人不必永远准时，但需要在变化发生时把你当成共同决定的人。"
          }
        ]
      },
      {
        "title": "被具体选择",
        "rules": [
          {
            "default": true,
            "text": "你要的不是被填进空档，而是在对方有完整生活时仍然被明确想起。"
          }
        ]
      },
      {
        "title": "普通星期天",
        "rules": [
          {
            "default": true,
            "text": "关系真正稳定以后，星期天可以一起过，也可以各自过；它不需要成为爱的考勤表。"
          }
        ]
      }
    ],
    "match": {
      "base": "适合你的人首先应该让你真的想靠近。他可以有自己的工作、执念和时间表，但不能默认你的时间会自动配合。他需要说清改变，也接受你最终不留下。",
      "appendRules": [
        {
          "when": {
            "trait": "validation",
            "gte": 58
          },
          "text": "他需要让偏爱落在具体行动里，不让你长期猜自己是不是一个临时空档。"
        },
        {
          "when": {
            "trait": "autonomy",
            "gte": 58
          },
          "text": "他必须尊重你保留朋友、独处和工作节奏，不用高质量约会占满全部生活。"
        },
        {
          "when": {
            "trait": "repair",
            "gte": 58
          },
          "text": "他可以犯错，但不能只靠一次漂亮道歉；之后的普通日子必须看得见改变。"
        }
      ]
    },
    "warning": {
      "rules": [
        {
          "when": {
            "all": [
              {
                "trait": "idealization",
                "gte": 58
              },
              {
                "trait": "discernment",
                "lte": 48
              }
            ]
          },
          "text": "放映室的光和一个好看的男人很容易让隐瞒显得浪漫。心动可以先发生，事实仍然要看清。"
        },
        {
          "when": {
            "trait": "care",
            "gte": 60
          },
          "text": "不要因为对方正在告别一件重要的事，就自动把自己的时间变成陪伴义务。"
        },
        {
          "default": true,
          "text": "准时、会安排和工作能力都很迷人；真正适合继续的人，还要能承认计划里出现了另一个有自己时间的人。"
        }
      ]
    }
  }
}