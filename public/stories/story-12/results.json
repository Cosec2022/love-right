  "sections": {
    "ending": {
      "byOutcome": {
        "partner": "你们把关系放进普通日常：星期天、提前五分钟和偶尔临时取消后的替代日期。许知行不要求报备，你也不必用猜测维持安全感。",
        "steady": "你们继续稳定约会，但不把节奏赶成身份。每一次改期都有说明，每一个星期天都可以重新选择。",
        "friends": "你们保留一段诚实的联系。家庭邀请没有变成压力，约会节奏也没有吞掉各自生活。",
        "end": "你决定结束约会。许知行没有追赶或冷落；他把临时取消和替代日期留在已经完成的说明里。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "appeal",
            "equals": "steady"
          },
          "text": "他没有追问你为什么来，只把一直替你留着的另一张票递给你。海风吹过纸角，也把那句迟到的“我在等你”轻轻送到你面前。"
        },
        {
          "when": {
            "flag": "appeal",
            "equals": "witty"
          },
          "text": "他看见你时先笑了：“这次没有走错馆吧？”你也笑了。那些一路上的紧张，忽然被一句只有你们懂的话变得很轻。"
        },
        {
          "when": {
            "flag": "appeal",
            "equals": "gentle"
          },
          "text": "他先问你冷不冷，又停了一下，认真问：“我可以抱你吗？”你点头以后，海风像是忽然绕开了你们。"
        },
        {
          "when": {
            "flag": "appeal",
            "equals": "direct"
          },
          "text": "他没有再让你猜，只看着你说：“我喜欢你，也想认真走下去。”这一次，心动终于有了清楚的声音。"
        },
        {
          "default": true,
          "text": "你正在学习让心动和判断同时存在。真正适合你的浪漫，不会要求你取消边界，只会让你更愿意向前一步。"
        }
      ]
    },
    "psychology": {
      "byArchetype": {
        "clear-slow": "你会注意提前五分钟、临时取消和替代日期这些小事；它们让你判断稳定是否真的尊重边界。",
        "steady-confirm": "你会注意提前五分钟、临时取消和替代日期这些小事；它们让你判断稳定是否真的尊重边界。",
        "romantic-resonance": "你会注意提前五分钟、临时取消和替代日期这些小事；它们让你判断稳定是否真的尊重边界。",
        "direct-pursuit": "你会注意提前五分钟、临时取消和替代日期这些小事；它们让你判断稳定是否真的尊重边界。",
        "free-close": "你会注意提前五分钟、临时取消和替代日期这些小事；它们让你判断稳定是否真的尊重边界。",
        "chosen-sensitive": "你会注意提前五分钟、临时取消和替代日期这些小事；它们让你判断稳定是否真的尊重边界。",
        "repair-nurturer": "你会注意提前五分钟、临时取消和替代日期这些小事；它们让你判断稳定是否真的尊重边界。",
        "push-pull": "你会注意提前五分钟、临时取消和替代日期这些小事；它们让你判断稳定是否真的尊重边界。"
      },
      "appendRules": [
        {
          "when": {
            "path": "spatial.trend.approach",
            "op": ">=",
            "value": 0.18
          },
          "text": "你在故事后半段明显比开始时更愿意靠近。你并非被第一眼征服，而是会被持续一致的细节慢慢说服。"
        },
        {
          "when": {
            "path": "spatial.trend.approach",
            "op": "<=",
            "value": -0.18
          },
          "text": "越接近现实选择，你反而越会收回冲动。你需要确认对方能承担关系，而不只是擅长让人心动。"
        },
        {
          "when": {
            "trait": "autonomy",
            "gte": 62
          },
          "text": "你需要亲密，也需要完整的自我。对方越尊重你的节奏，你越可能主动把他放进生活。"
        },
        {
          "default": true,
          "text": "你在靠近与保留之间相对平衡，不会立刻交出全部，也不需要靠故意冷淡证明自己。"
        }
      ]
    },
    "history": {
      "groups": [
        [
          {
            "default": true,
            "text": "你可能经历过需要猜测的关系，所以格外在意取消是否有说明和新的安排。"
          }
        ],
        [
          {
            "default": true,
            "text": "你不把慢速理解成冷淡；你是在为自己的约会节奏保留位置。"
          }
        ]
      ]
    },
    "future": [
      {
        "title": "星期天",
        "rules": [
          {
            "default": true,
            "text": "下一个星期天仍可重新协商，不必靠默认规则维系。"
          }
        ]
      },
      {
        "title": "替代日期",
        "rules": [
          {
            "default": true,
            "text": "临时变化被说明，也被新的日期接住。"
          }
        ]
      },
      {
        "title": "普通日常",
        "rules": [
          {
            "default": true,
            "text": "稳定来自可兑现的小事，而不是控制彼此的行程。"
          }
        ]
      }
    ],
    "match": {
      "base": "适合你的人会提前说明改变、给出替代日期，也接受你不排他或不参加家庭邀请。",
      "appendRules": []
    },
    "warning": {
      "rules": [
        {
          "default": true,
          "text": "别把清楚安排误读成控制，也别把沉默的取消当成需要你独自消化的正常。"
        }
      ]
