      "prompt": "你会怎样回复？",
      "note": "有些关系从一句普通的话开始，真正暴露心意的是回复方式。",
      "choices": [
        {
          "id": "a",
          "text": "‘到了，你呢？’",
          "effects": {
            "directness": 1,
            "security": 1,
            "care": 1
          },
          "next": "s05_silence"
