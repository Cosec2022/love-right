  "sections": {
    "ending": {
      "byOutcome": {
        "same-train": "你接受了两周的巡演工作，以自己的合同和职责登上同一班列车。你不是为了证明爱而离开，也不是被陆惟带走；这段同行首先属于你的职业选择。你们的私人关系仍按演出以前说清的边界继续。两个人去往同一个方向，并没有取消各自的人生，反而让靠近第一次不需要以谁缩小自己为代价。",
        "next-station": "你留在原来的城市，陆惟按计划离开。你们没有把距离写成忠诚考试，也没有用一句“等我”代替具体安排。真正约好的日期、联系方法和关系边界继续有效；没有约好的部分仍然保持空白。离开成为一项需要共同处理的现实，而不再是他替你决定、你替他牺牲的理由。",
        "after-curtain": "你们承认彼此重要，也停止了恋爱方向。陆惟离开以后，联系只停留在朋友能够承担的位置：没有身体试探，没有模糊等待，也没有用曾经的吻要求未来。喜欢没有被嘲笑或否认，只是没有被继续写成一段关系。你保留了关心，也保留了不再向前的决定。",
        "lights-out": "演出结束以后，你们不再联系。陆惟没有用最后一晚请求重来，你也没有用含糊的告别延长等待。你可以承认自己喜欢过他，也可以承认三个月的沉默已经改变了答案。灯灭以后，结束不是惩罚，不是欲擒故纵，更不是等他回来证明什么；它只是你已经说清、也终于被尊重的事实。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "relationship",
            "equals": "try"
          },
          "text": "你曾明确选择开始一段关系，因此这个结局会按恋人之间已经说清的责任继续，而不是靠离别现场临时升级。"
        },
        {
          "when": {
            "flag": "relationship",
            "equals": "slow"
          },
          "text": "你选择的是有限期的尝试。靠近仍然存在，但一个月后的复盘和实际行动比今晚的情绪更重要。"
        },
        {
          "when": {
            "flag": "relationship",
            "equals": "friends"
          },
          "text": "你已经把边界定义为朋友。后续即使同行或见面，也不能把普通关心偷偷改写成恋爱。"
        },
        {
          "when": {
            "flag": "relationship",
            "equals": "end"
          },
          "text": "你已经明确结束私人关系。最后的拥抱、送站或同一段工作，都不能推翻这个事实。"
        },
        {
          "default": true,
          "text": "最后一个动作只决定靠近或告别的语气，不能改写演出以前已经形成的关系和实际安排。"
        }
      ]
    },
    "psychology": {
      "byArchetype": {
        "clear-slow": "你会听解释，也会看解释之后的人怎样行动。离别倒计时不会让你加速承诺；时间线、持续出现和可以兑现的下一步，才会让你重新考虑信任。",
        "steady-confirm": "你需要关系有明确位置。喜欢可以慢，但不能靠猜；对方是否持续回应、遵守已经说出的边界，比一场漂亮告白更能让你留下。",
        "romantic-resonance": "你会被空舞台、雨路和一条没发出的消息打动，也允许离别拥有情绪。但真正决定你是否靠近的，仍是浪漫有没有尊重现实和选择权。",
        "direct-pursuit": "你倾向把关键问题直接问出口。你不愿把九天耗在试探里；一个明确答案即使不够甜，也比长久沉默更值得面对。",
        "free-close": "你允许亲密，也坚持自己的工作、城市和节奏。同行可以是爱，留下也可以是爱；任何关系都不能要求你先把自己缩小。",
        "chosen-sensitive": "你在意的不只是被喜欢，而是自己有没有被真正放进对方的计划。隐瞒会刺痛你，因为你需要的是被当作能够理解真相、作出回答的人。",
        "repair-nurturer": "你愿意看见一个人笨拙地改正，也能承认具体进步。但你不会只安慰他的后悔；修复必须表现为不再消失、尊重边界和持续承担。",
        "push-pull": "你可能同时被他的靠近打动，又被三个月的沉默推远。你的摇摆不是没有立场，而是在确认这次靠近会不会再次变成需要你独自收拾的空白。"
      },
      "appendRules": [
        {
          "default": true,
          "text": "你没有把爱情写成“跟不跟他走”的单选题，而是在喜欢、信任和自己的生活之间作出实际选择。"
        }
      ]
    },
    "history": {
      "groups": [
        [
          {
            "when": {
              "flag": "hurt_focus",
              "equals": "choice"
            },
            "text": "你最敏感的是别人以保护之名替你决定。过去的关系里，你可能经历过好意和控制混在一起，因此现在更看重知情权。"
          },
          {
            "when": {
              "flag": "hurt_focus",
              "equals": "silence"
            },
            "text": "亲密之后突然失去回应，会比直接拒绝更容易留下不安。你需要确认对方不会把沉默变成你一个人的解释任务。"
          },
          {
            "when": {
              "flag": "hurt_focus",
              "equals": "late-choice"
            },
            "text": "你可能很在意自己是否被明确选择。不是为了赢过谁，而是不愿在一段关系结束前才知道自己曾经重要。"
          },
          {
            "when": {
              "flag": "hurt_focus",
              "equals": "truth"
            },
            "text": "距离本身未必最让你害怕。你更难接受的是对方低估你的承受力，并以此决定哪些真相可以告诉你。"
          },
          {
            "default": true,
            "text": "你面对的是一张提前买好的车票，以及三个月没有被好好解释的沉默。"
          }
        ],
        [
          {
            "when": {
              "flag": "talk_mode",
              "equals": "written"
            },
            "text": "你拒绝了当面谈话，但允许书面说明成为新的沟通条件。边界没有终止故事，也没有被故事忘记。"
          },
          {
            "when": {
              "flag": "tour_option",
              "equals": "consider"
            },
            "text": "当同方向的工作机会出现时，你先看合同而不是把它当成命运。这让职业选择保留了自己的理由。"
          },
          {
            "when": {
              "flag": "tour_option",
              "equals": "decline"
            },
            "text": "你没有因为喜欢一个人就改变既有责任。留下不是胆怯，也不需要被包装成牺牲。"
          },
          {
            "default": true,
            "text": "你不仅听陆惟说了什么，也看见他之后是否持续出现、是否先询问边界、是否不再替你决定。"
          }
        ]
      ]
    },
    "future": [
      {
        "title": "离开不等于消失",
        "rules": [
          {
            "default": true,
            "text": "真正能继续的关系，不需要用“永远”消灭不确定，而需要有人在变化发生时及时说明。"
          }
        ]
      },
      {
        "title": "同一方向也要有自己的理由",
        "rules": [
          {
            "when": {
              "flag": "plan",
              "equals": "join"
            },
            "text": "你可以和喜欢的人同行，但工作合同、职责和成长必须仍然属于你自己。"
          },
          {
            "default": true,
            "text": "无论去或留，职业选择都不负责证明爱情。"
          }
        ]
      },
      {
        "title": "把说清变成日常",
        "rules": [
          {
            "default": true,
            "text": "一次坦白不能永久修复沉默。真正的变化要出现在下一次忙碌、害怕和想逃的时候。"
          }
        ]
      }
    ],
    "match": {
      "base": "适合你的人不会把离别制造成压力，也不会用“为你好”替你回答。他会表达自己的希望，同时尊重你的工作、时间和拒绝。",
      "appendRules": []
    },
    "warning": {
      "rules": [
        {
          "default": true,
          "text": "不要把迟到的坦白自动当成深情，也不要把一场漂亮演出当成关系已经修复。看他离开以后，是否仍然按照说过的话行动。"
        }
      ]
    }
  }
}