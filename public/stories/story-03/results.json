  "archetypes": [
    {
      "id": "clear-slow",
      "title": "清醒慢热型",
      "tagline": "你会心动，但不会因为心动取消判断。",
      "tags": [
        "慢热",
        "看行动",
        "保留边界",
        "一旦确认很认真"
      ]
    },
    {
      "id": "steady-confirm",
      "title": "稳定确认型",
      "tagline": "你真正会留下的关系，必须既有喜欢，也有明确的位置。",
      "tags": [
        "需要明确",
        "重视承诺",
        "稳定回应",
        "不爱猜"
      ]
    },
    {
      "id": "romantic-resonance",
      "title": "浪漫共振型",
      "tagline": "你会被细节、氛围和只属于两个人的暗号打动。",
      "tags": [
        "吃细节",
        "重氛围",
        "心动记忆",
        "愿意相信感觉"
      ]
    },
    {
