  "sections": {
    "ending": {
      "byOutcome": {
        "return": "闻野出发前，你们先定下下一次见面的日期，再讨论更远的以后。谁也没有辞掉工作，也没有用牺牲证明认真。那扇门锁上的一夜仍然重要，但真正让关系成立的是天亮以后，你们都没有消失。",
        "commute": "你们从三次正式约会开始。第一次发生在白天，没有酒店房卡、暴雨或拍摄任务。身体已经靠近过，却没有替你们跳过重新认识。闻野仍然好看，也终于要靠现实里的耐心继续得到你。",
        "distance": "你承认那一夜有欲望、有温柔，也有真实的喜欢。它不需要变成长久关系才值得被记住。闻野没有用最后一次拥抱改变你的决定，你也没有为了显得清醒，把短暂说成错误。",
        "farewell": "项目结束后，你们只通过正式邮件完成交付。闻野没有再用照片、欲望或离开的期限敲你的门。你没有否认曾经心动，只是不再把自己交给一个在关键事实前选择沉默的人。"
      },
      "appendRules": [
        {
          "when": {
            "flag": "appeal",
            "equals": "direct"
          },
          "text": "你最先记住的是他不躲人的目光，以及把想要说得足够清楚。"
        },
        {
          "when": {
            "flag": "appeal",
            "equals": "focused"
          },
          "text": "你被他的专注吸引，也看见专注一旦失去边界，会变成替别人决定。"
        },
        {
          "when": {
            "flag": "appeal",
            "equals": "steady"
          },
          "text": "他好看的不只是外表，还有工作失控时仍能把事情做稳的能力。"
        },
        {
          "when": {
            "flag": "appeal",
            "equals": "quiet"
          },
          "text": "他没有用热闹追你，真正留下来的，是那些安静却明确的目光。"
        },
        {
          "default": true,
          "text": "你记住的不只是那一夜，而是自己在每一次靠近与停止里都拥有选择。"
        }
      ]
    },
    "psychology": {
      "byArchetype": {
        "clear-slow": "你不是难以心动，而是不愿意用想象替别人补完人品。你会观察一个人怎样处理边界、承诺和麻烦；只有行动长期一致，你才会把柔软交出来。",
        "steady-confirm": "你真正需要的是可理解、可落地的关系。你可以接受忙碌和现实，但不愿长期依靠猜测维持安全感。对方主动说明、兑现安排，会比偶尔的浓烈更打动你。",
        "romantic-resonance": "你会记住别人忽略的小事：一句话的停顿、递过来的东西、只属于两个人的暗号。你不是只爱浪漫，而是通过这些细节确认彼此是否真的看见了对方。",
        "direct-pursuit": "你对喜欢相对诚实。你可以承担靠近以后不如预期，却很难接受两个人明明在意，还要靠冷淡和试探维持体面。你欣赏同样敢于表达的人。",
        "free-close": "你希望爱情让生活变大，而不是让生活只剩爱情。你能投入，也需要独处、朋友、工作和自己的节奏。越不试图控制你的人，越容易得到你的主动靠近。",
        "chosen-sensitive": "你在意的不是形式上的追求，而是稳定的优先级。偶尔热烈不难，真正让你放心的是：关系出现现实压力时，对方仍然没有把你放回可有可无的位置。",
        "repair-nurturer": "你对关系有很强的维护能力。你会解释、体谅，也愿意在冲突后多走一步。你的优势是长情，风险是容易把本应由两个人完成的修复独自扛完。",
        "push-pull": "你会在靠近时保留退路，也会在准备离开时重新想起那些好。不是你故意制造拉扯，而是心动和自我保护常常同时启动。真正适合你的人需要稳定，而不是更会制造悬念。"
      },
      "appendRules": [
        {
          "when": {
            "path": "spatial.trend.approach",
            "op": ">=",
            "value": 0.18
          },
          "text": "你在故事后半段明显比开始时更愿意靠近。你并非被第一眼征服，而是会被持续一致的细节慢慢说服。"
        },
        {
          "when": {
            "path": "spatial.trend.approach",
            "op": "<=",
            "value": -0.18
          },
          "text": "越接近现实选择，你反而越会收回冲动。你需要确认对方能承担关系，而不只是擅长让人心动。"
        },
        {
          "when": {
            "trait": "autonomy",
            "gte": 62
          },
          "text": "你需要亲密，也需要完整的自我。对方越尊重你的节奏，你越可能主动把他放进生活。"
        },
        {
          "default": true,
          "text": "你在靠近与保留之间相对平衡，不会立刻交出全部，也不需要靠故意冷淡证明自己。"
        }
      ]
    },
    "history": {
      "groups": [
        [
          {
            "when": {
              "all": [
                {
                  "trait": "reassurance",
                  "gte": 58
                },
                {
                  "trait": "abandonment",
                  "gte": 56
                }
              ]
            },
            "text": "你过去可能经历过回应突然变少、关系迟迟不被定义，或总要从细节里判断对方还在不在意。这让你后来更需要明确，也更怕自己显得太需要。"
          },
          {
            "when": {
              "all": [
                {
                  "trait": "autonomy",
                  "gte": 60
                },
                {
                  "trait": "discernment",
                  "gte": 58
                }
              ]
            },
            "text": "你可能经历过一段让你觉得被管束、被要求调整太多，或在失望后才发现自己早已让出边界的关系。因此你后来更习惯先观察，再决定是否投入。"
          },
          {
            "when": {
              "trait": "idealization",
              "gte": 61
            },
            "text": "你可能曾经喜欢过一个并没有真正进入生活的人。关系未必正式开始，但某些细节和未完成感留了很久，让你知道想象也会形成真实的情绪。"
          },
          {
            "default": true,
            "text": "你过去大概不总是遇到坏人，更像遇到过“彼此有好感，但表达方式和节奏不匹配”的关系。你能理解很多事，却会在小失望累积后突然安静。"
          }
        ],
        [
          {
            "when": {
              "all": [
                {
                  "trait": "care",
                  "gte": 58
                },
                {
                  "trait": "repair",
                  "gte": 58
                }
              ]
            },
            "text": "你往往愿意替关系多做一步：解释、照顾、等对方缓过来。它让你很有长期能力，也可能让你忽略，对方是否在同样认真地维护你。"
          },
          {
            "when": {
              "trait": "conflict",
              "lte": 44
            },
            "text": "你不喜欢在情绪最满时争论，经常先退开整理。别人可能误以为你不在意，其实你是在确认说出口以后会不会让关系更糟。"
          },
          {
            "when": {
              "trait": "discernment",
              "gte": 62
            },
            "text": "一旦某个行为改变了你对一个人的判断，你很难仅靠解释恢复信任。别人以为你突然冷了，实际上你通常已经观察了很久。"
          },
          {
            "default": true,
            "text": "你不太愿意把自己写成受伤的人，常常先替对方找现实理由。直到某个小细节重复出现，你才承认这段关系可能并不适合。"
          }
        ]
      ]
    },
    "future": [
      {
        "title": "相遇",
        "rules": [
          {
            "when": {
              "trait": "commitment",
              "gte": 59
            },
            "text": "下一段重要关系更可能从稳定重复的接触开始：同一个项目、常去的地方或共同负责的一件事。你不是被一场表白征服，而是在合作里逐渐确认他值得信任。"
          },
          {
            "when": {
              "trait": "novelty",
              "gte": 58
            },
            "text": "下一次明显心动，可能发生在一次临时回程、短期项目或原本只停留几天的地方。你没准备改变计划，却先被一个人的气质和做事方式留住。"
          },
          {
            "default": true,
            "text": "你更容易在真实生活的交集里认识重要的人。吸引不会立刻要求答案，而会先变成“我愿不愿意再和他做一件事”。"
          }
        ]
      },
      {
        "title": "转折",
        "rules": [
          {
            "when": {
              "trait": "expression",
              "gte": 58
            },
            "text": "真正的转折来自一次关于未来的直接谈话。你们不会用“再看看”无限拖延，而会把距离、工作和期待具体说清。"
          },
          {
            "when": {
              "trait": "repair",
              "gte": 58
            },
            "text": "关系会在一次意见冲突后变深。不是因为没有受伤，而是双方都能承认自己的部分，并重新决定怎样继续。"
          },
          {
            "default": true,
            "text": "转折更可能发生在一个普通现实问题里：时间安排、去留、家人或工作压力。你会从他怎样处理麻烦，判断这份喜欢能否进入生活。"
          }
        ]
      },
      {
        "title": "稳定",
        "rules": [
          {
            "when": {
              "trait": "autonomy",
              "gte": 60
            },
            "text": "稳定关系不会要求你缩小生活。你们会保留各自方向，同时建立固定的见面、说明和共同决定。"
          },
          {
            "when": {
              "trait": "commitment",
              "gte": 61
            },
            "text": "一旦确认彼此，你会把对方自然写进未来安排。稳定不是天天黏在一起，而是计划改变时仍然会把对方算进去。"
          },
          {
            "default": true,
